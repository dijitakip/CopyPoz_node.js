generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int           @id @default(autoincrement())
  username              String        @unique @db.VarChar(50)
  email                 String        @unique @db.VarChar(100)
  password_hash         String        @db.VarChar(255)
  role                  UserRole      @default(viewer)
  status                Status        @default(active)
  auth_token            String?       @unique @db.VarChar(255)
  auth_token_expires    DateTime?
  created_at            DateTime      @default(now()) @db.Timestamp(0)
  updated_at            DateTime      @default(now()) @updatedAt @db.Timestamp(0)
  lockout_until         DateTime?
  login_attempts        Int           @default(0)
  created_by            Int?
  deleted_at            DateTime?
  token_balance         Decimal       @default(0.00) @db.Decimal(15, 2)
  commission_rate       Decimal       @default(10.00) @db.Decimal(5, 2)
  referral_code         String?       @unique @db.VarChar(20)
  referred_by_id        Int?
  assigned_clients      Client[]      @relation("AssignedTo")
  owned_clients         Client[]      @relation("Owner")
  master_groups_created MasterGroup[] @relation("GroupCreator")
  system_logs           SystemLog[]
  user_tokens_created   UserToken[]   @relation("TokenCreator")
  user_tokens           UserToken[]   @relation("UserToken")
  creator               User?         @relation("UserCreator", fields: [created_by], references: [id])
  created_users         User[]        @relation("UserCreator")
  referrer              User?         @relation("UserReferrals", fields: [referred_by_id], references: [id])
  referred_users        User[]        @relation("UserReferrals")

  @@index([username])
  @@index([email])
  @@index([role])
  @@index([status])
  @@index([created_by], map: "users_created_by_fkey")
  @@index([referred_by_id], map: "users_referred_by_id_fkey")
  @@map("users")
}

model Client {
  id                   Int                     @id @default(autoincrement())
  account_number       BigInt                  @unique
  account_name         String                  @default("Unknown") @db.VarChar(100)
  owner_id             Int?
  assigned_to_user_id  Int?
  auth_token           String?                 @unique @db.VarChar(512)
  balance              Decimal                 @default(0.00) @db.Decimal(15, 2)
  equity               Decimal                 @default(0.00) @db.Decimal(15, 2)
  margin               Decimal                 @default(0.00) @db.Decimal(15, 2)
  free_margin          Decimal                 @default(0.00) @db.Decimal(15, 2)
  margin_level         Decimal                 @default(0.00) @db.Decimal(10, 2)
  open_positions       Int                     @default(0)
  status               ClientStatus            @default(active)
  last_seen            DateTime?
  created_at           DateTime                @default(now()) @db.Timestamp(0)
  updated_at           DateTime                @default(now()) @updatedAt @db.Timestamp(0)
  sync_buy             Boolean                 @default(true)
  sync_sell            Boolean                 @default(true)
  max_drawdown         Decimal                 @default(0.00) @db.Decimal(5, 2)
  monthly_profit_avg   Decimal                 @default(0.00) @db.Decimal(15, 2)
  multiplier           Decimal                 @default(1.00) @db.Decimal(10, 2)
  risk_score           Decimal                 @default(0.00) @db.Decimal(5, 2)
  suggested_multiplier Decimal                 @default(1.00) @db.Decimal(10, 2)
  token_balance        Decimal                 @default(0.00) @db.Decimal(15, 2)
  is_master            Boolean                 @default(false)
  min_collateral_rate  Decimal                 @default(20.00) @db.Decimal(5, 2)
  subscription_status  String                  @default("active") @db.VarChar(20)
  password             String?                 @db.VarChar(100)
  server               String?                 @db.VarChar(100)
  account_type         AccountType             @default(standard)
  assigned_to          User?                   @relation("AssignedTo", fields: [assigned_to_user_id], references: [id])
  owner                User?                   @relation("Owner", fields: [owner_id], references: [id])
  command_queue        CommandQueue[]
  master_assignments   MasterGroupAssignment[]
  master_groups_lead   MasterGroup[]           @relation("GroupMaster")
  performance_logs     PerformanceLog[]
  commission_reports   CommissionReport[]
  positions            Position[]
  system_logs          SystemLog[]             @relation("ClientLogs")
  trader_clients       TraderClient[]
  user_tokens          UserToken[]

  @@index([account_number])
  @@index([auth_token])
  @@index([status])
  @@index([last_seen])
  @@index([assigned_to_user_id], map: "clients_assigned_to_user_id_fkey")
  @@index([owner_id], map: "clients_owner_id_fkey")
  @@map("clients")
}

model PerformanceLog {
  id               Int      @id @default(autoincrement())
  client_id        Int
  date             DateTime @db.Date
  balance_start    Decimal  @db.Decimal(15, 2)
  balance_end      Decimal  @db.Decimal(15, 2)
  equity_min       Decimal  @db.Decimal(15, 2)
  equity_max       Decimal  @db.Decimal(15, 2)
  drawdown_percent Decimal  @db.Decimal(5, 2)
  profit_loss      Decimal  @db.Decimal(15, 2)
  multiplier_used  Decimal  @db.Decimal(10, 2)
  created_at       DateTime @default(now()) @db.Timestamp(0)
  client           Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([date])
  @@map("performance_logs")
}

model MasterState {
  id              Int      @id @default(autoincrement())
  total_positions Int      @default(0)
  positions_json  String?  @db.LongText
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@map("master_state")
}

model CommandQueue {
  id             Int           @id @default(autoincrement())
  client_id      Int
  command        String        @db.VarChar(50)
  params         String?       @db.Text
  status         CommandStatus @default(pending)
  created_at     DateTime      @default(now()) @db.Timestamp(0)
  executed_at    DateTime?
  result_message String?       @db.Text
  client         Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@index([status])
  @@map("command_queue")
}

model MasterGroup {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @db.VarChar(100)
  description           String?                 @db.Text
  created_by            Int
  created_at            DateTime                @default(now()) @db.Timestamp(0)
  updated_at            DateTime                @default(now()) @updatedAt @db.Timestamp(0)
  master_client_id      Int?
  owner_share_rate      Decimal                 @default(10.00) @db.Decimal(5, 2)
  total_commission_rate Decimal                 @default(40.00) @db.Decimal(5, 2)
  assignments           MasterGroupAssignment[]
  creator               User                    @relation("GroupCreator", fields: [created_by], references: [id])
  master_client         Client?                 @relation("GroupMaster", fields: [master_client_id], references: [id])

  @@index([master_client_id])
  @@index([created_by], map: "master_groups_created_by_fkey")
  @@map("master_groups")
}

model MasterGroupAssignment {
  id         Int         @id @default(autoincrement())
  group_id   Int
  master_id  Int?
  client_id  Int
  created_at DateTime    @default(now()) @db.Timestamp(0)
  client     Client      @relation(fields: [client_id], references: [id], onDelete: Cascade)
  group      MasterGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id])
  @@index([client_id])
  @@map("master_group_assignments")
}

model UserToken {
  id          Int       @id @default(autoincrement())
  user_id     Int
  client_id   Int?
  token_value String    @unique @db.VarChar(512)
  token_type  TokenType @default(CLIENT_TOKEN)
  status      Status    @default(active)
  created_by  Int
  created_at  DateTime  @default(now()) @db.Timestamp(0)
  expires_at  DateTime?
  last_used   DateTime?
  client      Client?   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  creator     User      @relation("TokenCreator", fields: [created_by], references: [id])
  user        User      @relation("UserToken", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([client_id])
  @@index([token_value])
  @@index([status])
  @@index([created_by], map: "user_tokens_created_by_fkey")
  @@map("user_tokens")
}

model License {
  id               Int         @id @default(autoincrement())
  license_key      String      @unique @db.VarChar(50)
  type             LicenseType @default(TRIAL)
  status           Status      @default(active)
  expiry_date      DateTime
  max_clients      Int         @default(1)
  last_check_date  DateTime?
  last_terminal_id String?     @db.VarChar(100)
  created_at       DateTime    @default(now()) @db.Timestamp(0)

  @@index([license_key])
  @@index([status])
  @@map("licenses")
}

model TraderClient {
  id          Int      @id @default(autoincrement())
  trader_id   Int
  client_id   Int
  assigned_by Int
  status      Status   @default(active)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamp(0)
  client      Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@unique([trader_id, client_id])
  @@index([trader_id])
  @@index([client_id])
  @@map("trader_clients")
}

model PasswordReset {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([token])
  @@index([user_id])
  @@map("password_resets")
}

model SystemLog {
  id         Int      @id @default(autoincrement())
  action     String   @db.VarChar(50)
  details    String?  @db.Text
  ip_address String?  @db.VarChar(45)
  user_id    Int?
  level      LogLevel @default(INFO)
  created_at DateTime @default(now()) @db.Timestamp(0)
  client_id  Int?
  client     Client?  @relation("ClientLogs", fields: [client_id], references: [id])
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([action])
  @@index([level])
  @@index([created_at])
  @@index([client_id], map: "system_logs_client_id_fkey")
  @@index([user_id], map: "system_logs_user_id_fkey")
  @@map("system_logs")
}

model Position {
  id            Int      @id @default(autoincrement())
  client_id     Int
  ticket        BigInt
  symbol        String   @db.VarChar(20)
  type          Int
  volume        Decimal  @db.Decimal(10, 2)
  open_price    Decimal  @db.Decimal(10, 5)
  sl            Decimal? @db.Decimal(10, 5)
  tp            Decimal? @db.Decimal(10, 5)
  current_price Decimal? @db.Decimal(10, 5)
  profit        Decimal? @db.Decimal(15, 2)
  swap          Decimal? @default(0.00) @db.Decimal(10, 2)
  commission    Decimal? @default(0.00) @db.Decimal(10, 2)
  open_time     DateTime @db.Timestamp(0)
  close_time    DateTime? @db.Timestamp(0)
  close_price   Decimal? @db.Decimal(10, 5)
  is_closed     Boolean  @default(false)
  master_ticket BigInt?  // Hangi master işleminin kopyası
  execution_ms  Int?     // Master'dan sonra kaç milisaniyede açıldı
  slippage      Decimal? @db.Decimal(10, 5) // Fiyat kayması (pips veya raw)
  last_update   DateTime @default(now()) @updatedAt @db.Timestamp(0)
  client        Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@unique([client_id, ticket])
  @@index([client_id])
  @@map("positions")
}

model CommissionReport {
  id                Int      @id @default(autoincrement())
  client_id         Int
  group_id          Int
  month             String   @db.VarChar(7) // e.g. "2024-03"
  total_profit      Decimal  @db.Decimal(15, 2)
  commission_amount Decimal  @db.Decimal(15, 2)
  owner_amount      Decimal  @db.Decimal(15, 2)
  system_amount     Decimal  @db.Decimal(15, 2)
  payment_status    String   @default("unpaid") @db.VarChar(20)
  approved_at       DateTime?
  approved_by_id    Int?
  created_at        DateTime @default(now()) @db.Timestamp(0)

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@unique([client_id, month], name: "client_id_month")
  @@map("commission_reports")
}

enum AccountType {
  standard
  cent
}

enum UserRole {
  admin
  master_owner
  trader
  viewer
}

enum Status {
  active
  inactive
}

enum ClientStatus {
  pending
  active
  inactive
  paused
  disconnected
}

enum CommandStatus {
  pending
  processing
  executed
  failed
  cancelled
}

enum TokenType {
  CLIENT_TOKEN
  TRADER_TOKEN
  MASTER_TOKEN
  ADMIN_TOKEN
}

enum LicenseType {
  TRIAL
  PRO
  ENTERPRISE
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  DEBUG
}
